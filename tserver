#!/data/data/com.termux/files/usr/bin/bash

# =====================
# VERSION CONFIG
# =====================
TERRARIA_VERSION="1455"
# =====================

# Setup shared storage if needed
if [ ! -d "$HOME/storage" ]; then
    echo "Requesting storage permissions..."
    termux-setup-storage
    if [ $? -ne 0 ]; then
        echo "Failed to set up storage. Exiting."
        exit 1
    fi
    echo "Storage permissions granted."
fi

read -p "Enter the directory name for your Terraria server: " directory_name
SERVER_DIR="$HOME/storage/shared/$directory_name"
INSTALL_DIR="$SERVER_DIR/$TERRARIA_VERSION/Linux"

# Check if already installed
if [ -d "$INSTALL_DIR" ]; then
    clear
    echo "Terraria $TERRARIA_VERSION already installed. Launching..."
    mono --server --gc=sgen -O=all "$INSTALL_DIR/TerrariaServer.exe"
else
    clear
    echo "Terraria $TERRARIA_VERSION not found. Installing..."

    pkg update -y && pkg upgrade -y
    pkg install -y mono wget unzip

    mkdir -p "$SERVER_DIR"
    cd "$SERVER_DIR" || { echo "Failed to access server directory. Exiting."; exit 1; }

    echo "Downloading Terraria server $TERRARIA_VERSION..."
    wget "https://terraria.org/api/download/pc-dedicated-server/terraria-server-${TERRARIA_VERSION}.zip" -O terraria-server.zip
    if [ $? -ne 0 ]; then
        echo "Error downloading Terraria server. Exiting."
        exit 1
    fi

    unzip terraria-server.zip
    rm terraria-server.zip

    cd "$INSTALL_DIR" || { echo "Failed to access Linux server directory. Exiting."; exit 1; }
    rm -f System* Mono* monoconfig mscorlib.dll

    # Create tserver launcher in PREFIX/bin (system-wide, like mcserver)
    TSERVER_PATH="$PREFIX/bin/tserver"
    if [ -f "$TSERVER_PATH" ]; then
        echo "Warning: \"tserver\" command already exists. Overwriting..."
    fi

    {
        echo "#!/data/data/com.termux/files/usr/bin/bash"
        echo "mono --server --gc=sgen -O=all \"$INSTALL_DIR/TerrariaServer.exe\""
    } > "$TSERVER_PATH"
    chmod +x "$TSERVER_PATH"

    clear
    echo "✅  Terraria $TERRARIA_VERSION installed successfully to: $SERVER_DIR"
    echo "➡️  You can now start the server by typing: tserver"
    echo ""
    echo "Starting Terraria server..."
    tserver
fi
